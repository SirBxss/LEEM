{
  "schema_version": "1.0.0",
  "experiment_name": "gaussian_synthetic_smoke",
  "dataset_root": "outputs/synthetic_smoke",
  "scenarios": [
    "conditional_gaussian",
    "latent_autoregressive",
    "nonlinear_heavy_tailed"
  ],
  "sample_count": 32,
  "sample_seed": 20260714,
  "evaluation": {
    "interval_levels": [0.50, 0.90, 0.95],
    "histogram_bin_count": 60,
    "histogram_clip_quantiles": [0.001, 0.999],
    "tail_probabilities": [0.95, 0.99],
    "crps_chunk_size": 2048,
    "max_distribution_values": 50000,
    "max_energy_frames": 300,
    "energy_pair_count": 256,
    "max_dependence_frames": 2000,
    "max_dependence_samples": 12,
    "metric_seed": 20260714
  },
  "gaussian_search": {
    "ridge_penalties": [0.0, 0.001],
    "covariance_shrinkages": [0.0, 0.10, 0.20],
    "minimum_eigenvalue": 0.000001,
    "minimum_station_observations": 32,
    "minimum_pair_observations": 32
  },
  "create_plots": true
}
