    "tail_probabilities": [0.95, 0.99],
    "crps_chunk_size": 4096,
    "max_distribution_values": 200000,
    "max_energy_frames": 2000,
    "energy_pair_count": 1024,
    "max_dependence_frames": 20000,
    "max_dependence_samples": 16,
    "metric_seed": 20260714
  },
  "gaussian_search": {
    "ridge_penalties": [0.0, 0.0001, 0.001, 0.01],
    "covariance_shrinkages": [0.0, 0.05, 0.10, 0.20, 0.40],
    "minimum_eigenvalue": 0.000001,
    "minimum_station_observations": 32,
    "minimum_pair_observations": 32
  },
  "create_plots": true
}
