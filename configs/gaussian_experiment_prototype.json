{
  "schema_version": "1.0.0",
  "experiment_name": "gaussian_synthetic_prototype",
  "dataset_root": "outputs/synthetic_prototype",
  "scenarios": [
    "conditional_gaussian",
    "latent_autoregressive",
    "nonlinear_heavy_tailed"
  ],
  "sample_count": 64,
  "sample_seed": 20260714,
  "evaluation": {
